<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         id="WebApp_ID"
         version="4.0">

    <display-name>GestionDesProduitMVC1 - Servlet Based</display-name>

    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>filters.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>web.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>web.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>web.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ListProduitServlet</servlet-name>
        <servlet-class>web.ListProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListProduitServlet</servlet-name>
        <url-pattern>/produits</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ListProduitServlet</servlet-name>
        <url-pattern>/listProduits</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddProduitServlet</servlet-name>
        <servlet-class>web.AddProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddProduitServlet</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AddProduitServlet</servlet-name>
        <url-pattern>/addProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditProduitServlet</servlet-name>
        <servlet-class>web.EditProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditProduitServlet</servlet-name>
        <url-pattern>/edit</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditProduitServlet</servlet-name>
        <url-pattern>/editProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateProduitServlet</servlet-name>
        <servlet-class>web.UpdateProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProduitServlet</servlet-name>
        <url-pattern>/update</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateProduitServlet</servlet-name>
        <url-pattern>/updateProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteProduitServlet</servlet-name>
        <servlet-class>web.DeleteProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteProduitServlet</servlet-name>
        <url-pattern>/delete</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteProduitServlet</servlet-name>
        <url-pattern>/deleteProduit</url-pattern>
    </servlet-mapping>


    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

</web-app>
